# Get your Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
# Get your Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# Primary AI provider for the intermediator: gpt, gemini, or groq.
# The others act as automatic fallbacks (in order) if the primary fails.
AI_PRIMARY=gpt
# OpenAI - default provider, and powers web-grounded triggers :ask / :factcheck.
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
# Chat model used by the intermediator when gpt is selected (default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini
# Search-enabled model used by :ask web-grounded answers (default: gpt-4o-mini-search-preview)
OPENAI_SEARCH_MODEL=gpt-4o-mini-search-preview
# Model used by :factcheck (gpt-5.1 only, per requirement)
OPENAI_FACTCHECK_MODEL=gpt-5.1
OCR_SPACE_API_KEY=your_ocr_space_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_ACCOUNT_ID=your_r2_account_id
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
